# MongoDB Atlas: use your connection string. If password has # or @, URL-encode it (# → %23, @ → %40).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MAHYCO_DB=mahyco_db
UPLOAD_DIR=./uploads

# Optional: external model API (e.g. local model via ngrok)
# Example: MODEL_API_URL=https://your-ngrok-id.ngrok-free.app/predict
MODEL_API_URL=

# Optional: local model integration folder (contains scripts/ and weights/)
# Example: WEBSITE_INTEGRATION_DIR=d:\\ssv\\website_integration
WEBSITE_INTEGRATION_DIR=
