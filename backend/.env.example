# PostgreSQL connection string used by SQLAlchemy + Alembic.
# Example: postgresql+asyncpg://postgres:postgres@localhost:5432/mahyco_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mahyco_db

# Writable folder for uploads and generated reports.
# This path is resolved relative to the backend process working directory unless you use an absolute path.
UPLOAD_DIR=./uploads

# JWT signing secret used for login tokens.
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Celery broker / backend for batch jobs.
REDIS_URL=redis://localhost:6379/0

# Optional: external model API (for proxying inference to another service).
MODEL_API_URL=

# Optional: local model integration folder containing scripts/ and weights/.
# Example on Windows: WEBSITE_INTEGRATION_DIR=d:\path\to\website_integration
WEBSITE_INTEGRATION_DIR=

# Optional verbose logging for debugging.
DEBUG_LOGGING=false
